# Article Group AI Concierge - Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE
# ===========================================
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# ANTHROPIC (Claude)
# ===========================================
# Get this from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# ===========================================
# OPENAI (for embeddings)
# ===========================================
# Get this from platform.openai.com
# Used for text-embedding-3-small
OPENAI_API_KEY=sk-xxxxx

# ===========================================
# LLAMACLOUD API (Document Parsing)
# ===========================================
# Get this from https://cloud.llamaindex.ai
# Pricing: ~$0.003 per page
LLAMA_CLOUD_API_KEY=llx-xxxxx

# ===========================================
# ADMIN API (protect /api/health, /api/analytics)
# ===========================================
# Generate a random token: openssl rand -hex 32
# In production, requests must include: Authorization: Bearer <token>
# In development, these endpoints are open without a token
ADMIN_API_TOKEN=

# ===========================================
# SENTRY (Error Monitoring)
# ===========================================
# Get this from sentry.io after creating a project
# SENTRY_DSN is server-side, NEXT_PUBLIC_SENTRY_DSN is client-side
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=sntrys_xxxxx

# ===========================================
# OPTIONAL
# ===========================================
# For development debugging
# DEBUG=true
